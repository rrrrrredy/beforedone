{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rrrrrredy.github.io/beforedone/schemas/incident.schema.json",
  "title": "BeforeDone incident report v1",
  "type": "object",
  "required": [
    "schema_version", "id", "created_at", "repository", "verdict",
    "first_observable_divergence", "timeline", "claim_evidence_matrix", "next_steps"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "repository": { "type": "string" },
    "base_commit": { "type": "string" },
    "head_commit": { "type": "string" },
    "verdict": { "enum": ["PASS", "FAIL", "INCONCLUSIVE"] },
    "first_observable_divergence": { "$ref": "#/$defs/divergence" },
    "timeline": { "type": "array", "items": { "$ref": "event.schema.json" } },
    "claim_evidence_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "evidence", "status"],
        "properties": {
          "claim": { "type": "string" },
          "evidence": { "type": "string" },
          "status": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "missing_evidence": { "type": "array", "items": { "type": "string" } },
    "user_correction": { "type": "string" },
    "transcript_supplement": {
      "type": "object",
      "required": ["sha256", "excerpt", "truncated", "statement"],
      "properties": {
        "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "excerpt": { "type": "string" },
        "truncated": { "type": "boolean" },
        "statement": { "type": "string" }
      },
      "additionalProperties": false
    },
    "diff_summary": { "type": "string" },
    "next_steps": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "divergence": {
      "type": "object",
      "required": ["precision", "reason"],
      "properties": {
        "precision": { "enum": ["exact_event", "time_window", "unlocated"] },
        "event_id": { "type": "string", "minLength": 1 },
        "start_event": { "type": "string", "minLength": 1 },
        "end_event": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "required": ["precision"],
            "properties": { "precision": { "const": "exact_event" } }
          },
          "then": {
            "required": ["event_id"],
            "not": { "anyOf": [{ "required": ["start_event"] }, { "required": ["end_event"] }] }
          }
        },
        {
          "if": {
            "required": ["precision"],
            "properties": { "precision": { "const": "time_window" } }
          },
          "then": {
            "required": ["start_event", "end_event"],
            "not": { "required": ["event_id"] }
          }
        },
        {
          "if": {
            "required": ["precision"],
            "properties": { "precision": { "const": "unlocated" } }
          },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["event_id"] },
                { "required": ["start_event"] },
                { "required": ["end_event"] }
              ]
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
