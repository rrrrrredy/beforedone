{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rrrrrredy.github.io/beforedone/schemas/adapter-manifest.schema.json",
  "title": "BeforeDone adapter manifest v1",
  "type": "object",
  "required": ["schema_version", "name", "version", "capabilities"],
  "properties": {
    "schema_version": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "object",
      "required": ["tool_events", "stop_retry", "subagents", "transcript"],
      "propertyNames": { "enum": ["tool_events", "stop_retry", "subagents", "transcript"] },
      "properties": {
        "tool_events": { "type": "boolean" },
        "stop_retry": { "type": "boolean" },
        "subagents": { "type": "boolean" },
        "transcript": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "event_map": {
      "type": "object",
      "additionalProperties": {
        "enum": ["SessionStarted", "PromptSubmitted", "ToolStarted", "ToolFinished", "AgentStopping", "SessionEnded"]
      }
    }
  },
  "additionalProperties": false
}
